{
  "name": "mcp-hub-lite",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-hub-lite": "./dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js start",
    "dev": "vite",
    "build": "run-p type-check build:client build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "validate:esm": "node --input-type=module -e \"console.log('ESM Environment Valid')\"",
    "type-check": "vue-tsc --noEmit -p tsconfig.frontend.json --composite false"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "commander": "^14.0.2",
    "element-plus": "^2.13.0",
    "fastify": "^5.6.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.0.3",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^7.3.0",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.1"
  }
}
