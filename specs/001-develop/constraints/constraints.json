    "performance": {
      "gatewayLatency": {
        "id": "SC-010",
        "name": "网关平均响应延迟",
        "value": "100ms",
        "type": "time",
        "priority": "P1",
        "measurement": "平均值，持续1分钟，95百分位",
        "scope": "gateway",
        "owner": "performance-team",
        "relatedTo": ["connectionTimeout", "serverResponseTimeout"],
        "lastUpdated": "2025-12-09",
        "updatedBy": "system-architect"
      },
      "searchResponseTime": {
        "id": "SC-003",
        "name": "搜索响应时间",
        "value": "500ms",
        "type": "time",
        "priority": "P2",
        "measurement": "平均在1000+工具目录中",
        "scope": "search",
        "owner": "search-team",
        "relatedTo": ["idleConnectionTimeout"],
        "lastUpdated": "2025-12-09",
        "updatedBy": "system-architect"
      },
      "debugInfoDisplay": {
        "id": "SC-006",
        "name": "调试信息显示延迟",
        "value": "3000ms",
        "type": "time",
        "priority": "P2",
        "measurement": "从MCP-Inspector首次请求调试信息到完整界面元素渲染完成的时间，采用自动化性能测试测量平均值",
        "scope": "debugging",
        "owner": "ui-team",
        "relatedTo": [],
        "lastUpdated": "2025-12-09",
        "updatedBy": "system-architect",
        "method": {
          "type": "automated",
          "tools": ["puppeteer", "lighthouse"],
          "metrics": ["first-contentful-paint", "largest-contentful-paint"],
          "sample_size": 100,
          "tolerance": 0.05
        }
      },
      "languageSwitchTime": {
        "id": "SC-009",
        "name": "语言切换响应时间",
        "value": "500ms",
        "type": "time",
        "priority": "P2",
