        "scope": "i18n",
        "owner": "ui-team",
        "relatedTo": [],
        "lastUpdated": "2025-12-09",
        "updatedBy": "system-architect",
        "method": {
          "type": "automated",
          "tools": ["jest", "i18next-parser"],
          "metrics": ["response-time-percentile-95"],
          "sample_size": 50,
          "tolerance": 0.1
        }
      },
