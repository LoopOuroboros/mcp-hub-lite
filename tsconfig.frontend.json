{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["frontend/src/**/*", "frontend/src/**/*.vue"],
  "exclude": ["src/**", "tests/**", "node_modules"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.frontend.tsbuildinfo",
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./frontend/src/*"]
    }
  }
}
